{
  "name": "@taylorvance/tv-shared-ui",
  "version": "0.1.4",
  "description": "Shared React UI primitives for Taylor Vance portfolio projects.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tv.svg": "./assets/tv.svg",
    "./tv.png": "./assets/tv.png"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-ui-package.mjs",
    "dev": "npm run build && tsc --watch --preserveWatchOutput -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/taylorvance/tv-shared",
    "directory": "packages/ui"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  }
}
