{
  "name": "@taylorvance/tv-shared-runtime",
  "version": "0.6.0",
  "description": "Shared React runtime primitives for Taylor Vance portfolio projects.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./BrandBadge": {
      "types": "./dist/BrandBadge.d.ts",
      "import": "./dist/BrandBadge.js",
      "default": "./dist/BrandBadge.js"
    },
    "./assets": {
      "types": "./dist/assets.d.ts",
      "import": "./dist/assets.js",
      "default": "./dist/assets.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js",
      "default": "./dist/storage.js"
    },
    "./hotkeys": {
      "types": "./dist/hotkeys.d.ts",
      "import": "./dist/hotkeys.js",
      "default": "./dist/hotkeys.js"
    },
    "./storage-dev": {
      "types": "./dist/storage-dev.d.ts",
      "import": "./dist/storage-dev.js",
      "default": "./dist/storage-dev.js"
    },
    "./tv.svg": "./assets/tv.svg",
    "./tv.png": "./assets/tv.png"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../../scripts/build-runtime-package.mjs",
    "clean": "rm -rf dist node_modules coverage .vite .eslintcache *.tsbuildinfo",
    "dev": "npm run build && tsc --watch --preserveWatchOutput -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/taylorvance/tv-shared",
    "directory": "runtime/node/tv-shared-runtime"
  },
  "dependencies": {
    "react-hotkeys-hook": "^5.1.0"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  }
}
